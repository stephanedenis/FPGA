--- a/src/jtag_hw_otma.cpp
+++ b/src/jtag_hw_otma.cpp
@@ find_devs — après mpsse_open @@
+    if (ctx) {
+      /* Fix Bug 3: TCK explicite 3 MHz */
+      mpsse_set_frequency(ctx, 3000000);
